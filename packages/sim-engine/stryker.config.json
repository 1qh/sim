{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-js/master/packages/api/schema/stryker-core.json",
  "packageManager": "npm",
  "reporters": ["clear-text"],
  "testRunner": "command",
  "commandRunner": {
    "command": "bun test src/index.test.ts src/replay.test.ts"
  },
  "mutate": ["src/codec.ts", "src/machine.ts", "src/rng.ts"],
  "thresholds": { "high": 90, "low": 70, "break": 70 },
  "checkers": [],
  "coverageAnalysis": "off",
  "tempDirName": ".stryker-tmp",
  "concurrency": 4,
  "timeoutMS": 60000
}
