{
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "readonly/ui"
  ],
  "scripts": {
    "action": "sh up.sh",
    "build": "turbo build --output-logs=errors-only",
    "check": "lintmax check",
    "clean": "sh clean.sh",
    "fix": "lintmax fix",
    "postinstall": "sherif",
    "prepare": "bunx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "sh up.sh && git add -u"
  },
  "overrides": {
    "@auth/core": "0.41.x"
  },
  "dependencies": {
    "pure-rand": "^8.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "latest",
    "@logtape/logtape": "latest",
    "@playwright/test": "latest",
    "@size-limit/preset-app": "latest",
    "@stryker-mutator/core": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/three": "latest",
    "axe-core": "latest",
    "convex-test": "latest",
    "fast-check": "latest",
    "happy-dom": "latest",
    "lintmax": "latest",
    "memlab": "latest",
    "pa11y": "latest",
    "sherif": "latest",
    "simple-git-hooks": "latest",
    "size-limit": "latest",
    "tinybench": "latest",
    "tsdown": "latest",
    "turbo": "latest",
    "typescript": "latest",
    "unlighthouse": "latest",
    "unrun": "latest",
    "wrangler": "^4.92.0"
  },
  "packageManager": "bun@1.3.13",
  "trustedDependencies": [
    "esbuild",
    "lintmax",
    "msw",
    "sharp",
    "simple-git-hooks"
  ]
}
